%% Velocity vs pycnocline depth

close all;

figure();
my_year = 5;  % Select the year index
my_data = data_all{my_year};  % Extract dataset

% Define the target longitude
target_longitude = 117.4;
tol = 0.1;  % Tolerance for floating point comparison

% Filter data where longitude is approximately 117.4
idx = abs(my_data.longitude - target_longitude) < tol;

% Extract filtered velocity and corresponding dates
velocity_filtered = my_data.velocity(idx);
dates_filtered = my_data.datetime(idx);

% Convert both to just 'yyyy-mm-dd' format
dates_filtered_str = datestr(dates_filtered, 'yyyy-mm-dd');  
all_dates_str = datestr(all_dates, 'yyyy-mm-dd'); 

% Find matching dates
[~, idx_mean] = ismember(dates_filtered_str, all_dates_str);  

% Ensure valid indices (ignore unmatched entries)
valid_idx = idx_mean > 0;
velocity_filtered = velocity_filtered(valid_idx);
mean_upper_layers_filtered = all_mean_upper_layers(idx_mean(valid_idx));

% Plot velocity vs mean upper layers
plot(velocity_filtered, mean_upper_layers_filtered, 'o')
xlabel('Velocity')
ylabel('Mean Upper Layer Value')
title(['Velocity vs Mean Upper Layer at Longitude = ', num2str(target_longitude)])
grid on;

%% Plot average velocity binned by depth
fs = 20;
% close all;
cmap = autumn(length(years));

fig = figure();

% for i = 1:length(years)
for i = 6
    
    % If only plotting specific times, define the time range
    start_date = datetime(years(i), 5, 1); 
    end_date = datetime(years(i), 8, 31); 
    
    % Find indices where datetime falls within the range
    range = (data_all{i}.datetime >= start_date) & (data_all{i}.datetime <= end_date);

    data_lon = longitude{i}(range);
    data_velocity = data_all{i}.velocity(range);
    
    % Match longitudes to corresponding average depths
    idx = knnsearch(lon(:), data_lon(:)); % knnsearch(X,Y) finds the nearest neighbor in X for each point in Y
    depths_at_data_lon = avg_depth_along_lon(idx); % Get average depths
    
    % Bin velocities by depth
    bin_edges = -2000:50:0; % bins for depth
    bin_centers = bin_edges(1:end-1) + diff(bin_edges)/2;
    [N, edges, bin_indices] = histcounts(depths_at_data_lon, bin_edges);
    
    % Average velocity per depth bin
    avg_velocity = arrayfun(@(b) mean(data_velocity(bin_indices == b), 'omitnan'), 1:length(bin_centers));
    std_velocity = arrayfun(@(b) std(data_velocity(bin_indices == b), 'omitnan'), 1:length(bin_centers));
    
    % Define x and y
    x = bin_centers;
    y = avg_velocity;
    
    % Get rate of slowing in shallow waters (after 900 m depth) & exclude
    % anomalous points
    valid_idx = (x>-900) & ~isnan(y) & ~isinf(y) & (y>1) & (y<3.5);
    x_clean = x(valid_idx);
    y_clean = y(valid_idx);
    
    % Perform polyfit on cleaned data
    p = polyfit(x_clean, y_clean, 1);
    slopes(i) = p(1);

    % subplot(2, 5, i)
    xline(-900, 'k--', 'LineWidth',2)
    hold on;
    errorbar(bin_centers, avg_velocity, std_velocity, 'k.', 'CapSize', 0, 'HandleVisibility', 'off');
    scatter(bin_centers, avg_velocity, 80, cmap(i, :), 'filled', 'DisplayName',num2str(years(i)), 'MarkerEdgeColor', 'k' );
    yline(3.23, 'b--', 'LineWidth',2)
    yline(2.22, 'b--', 'LineWidth',2)
    text(-850, 3.33, 'mean speed in deep basin (Ramp et al., 2010)', 'color', 'b')
    text(-850, 2.33, 'mean speed over cont. slope (Ramp et al., 2010)', 'color', 'b')
    % Perform polynomial fit
    x_fit = linspace(min(bin_centers), max(bin_centers), 100);
    y_fit = polyval(p, x_fit);  % Evaluate polynomial at x_fit
    
    % Plot the fit
    plot(x_fit, y_fit, 'r-', 'LineWidth', 1.5, 'DisplayName', 'Linear Fit');

    title(num2str(years(i)), 'FontSize', fs, 'FontAngle', 'italic');
    text(-1100,1.2, ['slope: ' num2str(slopes(i), '%.5f')], 'color', 'r')
    % xlabel('Depth (m)')
    % ylabel('Average velocity (m/s)')
    xlim([-1200, -400])
    ylim([0,3.5])
    grid on;

    % Bootstrapping

    % figure(i)

    f = y_clean;
    b = x_clean(:);
    
    N = length(f);  
    a = ones(N, 1);
    
    Nbs = 1000;  % Number of bootstrap samples
    
    c_store1 = zeros(Nbs, 1);  % Slope (for b)
    c_store2 = zeros(Nbs, 1);  % Intercept (for a)
    
    for k = 1:Nbs
        % Bootstrap resampling
        I = randi(N, 1, N);  % Resample indices with replacement
    
        % Resample data
        f_twiddle = f(I);  % Velocity (response variable)
        a_twiddle = a(I);  % Intercept term (constant ones)
        b_twiddle = b(I);  % Depths at sampled longitudes
    
        % Construct design matrix
        G_twiddle = [a_twiddle, b_twiddle];
    
        % Fit the model using least squares
        c_twiddle = (G_twiddle' * G_twiddle) \ (G_twiddle' * f_twiddle(:));
    
        % Store coefficients
        c_store1(k) = c_twiddle(2);  % Slope (depth coefficient)
        c_store2(k) = c_twiddle(1);  % Intercept
    
        % Predictions
        fhat_twiddle = G_twiddle * c_twiddle;
    
        % % Plot bootstrap sample and predictions
        % plot(b_twiddle, f_twiddle, '*', b_twiddle, fhat_twiddle, '.');
        % 
        % hold on;
    end
    
    % % Finalize plot
    % legend('actual velocity values', 'model predictions')
    % hold off;
    % grid on;
    % xlabel('Depth');
    % ylabel('Velocity');
    % title('Bootstrap Regression: Velocity vs Depth');
    
    % Calculate standard deviations of coefficients
    stdev_slope(i) = std(c_store1);
    stdev_int(i) = std(c_store2);


end

