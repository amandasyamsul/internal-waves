obs_y1 = obs_coords(1);
obs_y2 = obs_coords(1) + space*2;
% OBS bounds box
x = [obs_x1, obs_x2, obs_x2, obs_x1, obs_x1];
y = [obs_y1, obs_y1, obs_y2, obs_y2, obs_y1];
